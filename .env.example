# Build-time feature flags. Copy this file to `.env.local` (gitignored) and edit.
# Vite only exposes variables prefixed with VITE_ to the client bundle.

# Playground sandbox mode (Versus with deck-composition + hand-size knobs).
# Default: false. Set to true to surface the Playground entry on the main menu.
VITE_PLAYGROUND_ENABLED=false

# DevTools console commands (`window.chikReset`, etc).
# Default: ON in dev builds, OFF in production. Set explicitly to override.
# When false, `installChikResetCommand` no-ops so the reset utility isn't
# exposed on `window` in shipped builds.
VITE_DEVTOOL_COMMANDS_ENABLED=
